{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "components/**/*.vue",
    "vite-env.d.ts",
    "setup/**/*.ts"
  ]
}
